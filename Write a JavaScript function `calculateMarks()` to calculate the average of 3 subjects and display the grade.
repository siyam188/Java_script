function calculateMarks(m1, m2, m3) {
    let avg = (m1 + m2 + m3) / 3;

    if (avg >= 80)
        console.log("Grade: A+");
    else if (avg >= 70)
        console.log("Grade: A");
    else if (avg >= 60)
        console.log("Grade: A-");
    else if (avg >= 50)
        console.log("Grade: B");
    else
        console.log("Grade: F");
}

// Example
calculateMarks(85, 75, 90);
