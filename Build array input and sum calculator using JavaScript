<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loop an Array</title>
</head>
<body>

<script>
    var num = new Array();

    // Input 5 numbers
    for (var i = 0; i < 5; i++) {
        num[i] = parseInt(prompt("Enter a number:"));
    }

    var sum = 0;

    // Display numbers and calculate sum
    for (var i = 0; i < 5; i++) {
        console.log(num[i]);
        sum += num[i];
    }

    console.log("Total Sum: " + sum);
</script>

</body>
</html>
