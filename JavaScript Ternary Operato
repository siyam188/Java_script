<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JavaScript Ternary Operator</title>
</head>
<body>

<script>
    var num = parseInt(prompt("Enter a number:"));

    var result = (num % 2 == 0) ? "Even Number" : "Odd Number";

    console.log(result);
</script>

</body>
</html>
