<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Function with Parameters</title>
</head>
<body>

<script>
    function add(num1, num2) {
        document.write("Sum = " + (num1 + num2));
    }

    add(15, 25);
</script>

