<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JavaScript Grade Program</title>
</head>
<body>

<script>
    var marks = parseInt(prompt("Enter your marks:"));

    if (marks >= 80 && marks <= 100) {
        console.log("Grade: A+");
    }
    else if (marks >= 70) {
        console.log("Grade: A");
    }
    else if (marks >= 60) {
        console.log("Grade: A-");
    }
    else if (marks >= 50) {
        console.log("Grade: B");
    }
    else if (marks >= 40) {
        console.log("Grade: C");
    }
    else if (marks >= 33) {
        console.log("Grade: D");
    }
    else if (marks >= 0) {
        console.log("Grade: Fail");
    }
    else {
        console.log("Invalid Marks!");
    }
</script>

</body>
</html>
