<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Even or Odd</title>
</head>
<body>

<script>
    var num = 5;

    if (num % 2 == 0) {
        console.log(num + " is Even");
    } else {
        console.log(num + " is Odd");
    }
</script>

</body>
</html>
